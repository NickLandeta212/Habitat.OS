<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="Ventana">
  <grid id="root" binding="mainPanel" layout-manager="GridLayoutManager" row-count="2" column-count="1">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="900" height="600"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="title" class="javax.swing.JLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="20" style="1"/>
          <horizontalAlignment value="0"/>
          <text value="HABITAT.OS - Sistema de Gestión de Condominio"/>
        </properties>
      </component>
      <tabbedpane id="tabs" binding="tabs">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="cond" binding="condPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1">
            <margin top="5" left="5" bottom="5" right="5"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <tabbedpane title="Condóminos"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="area" binding="areaPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1">
            <margin top="5" left="5" bottom="5" right="5"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <tabbedpane title="Áreas Comunes"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="reserva" binding="reservaPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1">
            <margin top="5" left="5" bottom="5" right="5"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <tabbedpane title="Reservas"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="pago" binding="pagoPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1">
            <margin top="5" left="5" bottom="5" right="5"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <tabbedpane title="Pagos"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="multa" binding="multaPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1">
            <margin top="5" left="5" bottom="5" right="5"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <tabbedpane title="Multas"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="factura" binding="facturaPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1">
            <margin top="5" left="5" bottom="5" right="5"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <tabbedpane title="Facturas"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="acciones" binding="accionesPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1">
            <margin top="5" left="5" bottom="5" right="5"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <tabbedpane title="Acciones / Reportes"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
        </children>
      </tabbedpane>
    </children>
  </grid>
</form>
